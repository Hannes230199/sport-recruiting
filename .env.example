# Supabase
# Findest du in deinem Supabase-Projekt unter Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Nur serverseitig verwenden (z.B. für Scraper-Skripte, Cron-Jobs, Admin-Routen)
# NIEMALS im Client-Code oder mit NEXT_PUBLIC_ Prefix verwenden!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: User-Agent für die Scraper, damit faire Requests gesendet werden
SCRAPER_USER_AGENT="SportRecruitingBot/0.1 (+mailto:hannes.schwedhelm@ringier.ch)"

# Optional, aber für Produktion empfohlen: Secret, um den
# /api/scrape-trigger Endpoint abzusichern. Wenn eine Umgebungsvariable
# mit genau diesem Namen ("CRON_SECRET") in Vercel gesetzt ist, schickt
# Vercel Cron automatisch den Header "Authorization: Bearer <CRON_SECRET>"
# mit - siehe vercel.json und src/app/api/scrape-trigger/route.ts.
CRON_SECRET=change-me

# Basis-URL der App, wird für den Magic-Link-Redirect (Supabase Auth)
# benötigt. Lokal: http://localhost:3000. In Vercel auf die Produktions-
# Domain setzen (z.B. https://sport-recruiting.vercel.app). Falls nicht
# gesetzt, wird der Origin-Header der eingehenden Anfrage verwendet.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
